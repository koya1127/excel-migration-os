# App URL (REQUIRED in production — used for OAuth redirects, Stripe callbacks)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Backend API URL (REQUIRED in production — used for file uploads and API proxy)
# NEXT_PUBLIC_API_URL=https://your-backend.azurewebsites.net

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe billing (metered only)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_METERED=price_xxxxx
STRIPE_METER_ID=mtr_xxxxx
STRIPE_METER_EVENT_NAME=ai_tokens

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_REDIRECT_URI defaults to NEXT_PUBLIC_APP_URL/api/auth/google/callback
# Only set explicitly if using a different callback URL
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
