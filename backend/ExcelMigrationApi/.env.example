# Clerk authentication
CLERK_DOMAIN=your-clerk-domain.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_xxxxx

# Anthropic API (for VBA→GAS conversion)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_METER_EVENT_NAME=ai_tokens
STRIPE_METER_ID=mtr_xxxxx

# CORS — production frontend URL (omit for localhost-only)
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Azure Application Insights (set in production)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxxx;IngestionEndpoint=https://xxxxx.applicationinsights.azure.com/

# ASP.NET Core environment (set to Production for deployed environments)
# ASPNETCORE_ENVIRONMENT=Production
